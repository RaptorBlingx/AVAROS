# AVAROS Environment Configuration
# Copy this file to .env and customize as needed
# NOTE: Platform credentials should be entered via Web UI, not here

# ============================================================================
# General Settings
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
AVAROS_LOG_LEVEL=INFO

# Port for AVAROS API (if running standalone)
AVAROS_PORT=8080

# Timezone
TZ=UTC

# ============================================================================
# Data Persistence
# ============================================================================

# Path for SQLite database (settings, audit logs)
AVAROS_DATA_PATH=/data

# ============================================================================
# OVOS Settings (Optional Overrides)
# ============================================================================

# OVOS configuration path
# OVOS_CONFIG_PATH=/home/ovos/.config/mycroft

# ============================================================================
# Adapter Selection
# ============================================================================

# Which platform adapter to use (mock, reneryo, sap)
# "mock" provides demo data with no external dependencies (DEC-005)
ADAPTER_TYPE=mock

# ============================================================================
# Development Settings (Not for Production)
# ============================================================================

# Enable debug mode (more verbose logging)
# AVAROS_DEBUG=false

# Skip authentication (development only!)
# AVAROS_SKIP_AUTH=false
