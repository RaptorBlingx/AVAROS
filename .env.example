# ─────────────────────────────────────────────────────────────────────────────
# AVAROS Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and customize as needed.
# Platform credentials (RENERYO URL, API keys) are entered via the Web UI
# wizard — not here.
#
# Full reference: docs/ENV-REFERENCE.md
# ─────────────────────────────────────────────────────────────────────────────

# ============================================================================
# Database (PostgreSQL)
# ============================================================================

# PostgreSQL credentials used by docker-compose.avaros.yml.
POSTGRES_USER=avaros
# Set a strong password in production.
POSTGRES_PASSWORD=

# Connection URL for the PostgreSQL database.
# Default works with the Docker Compose setup (avaros_db service).
# Replace <password> with the value of POSTGRES_PASSWORD.
AVAROS_DATABASE_URL=postgresql://avaros:<password>@avaros_db:5432/avaros

# ============================================================================
# Platform Adapter
# ============================================================================

# Platform adapter is configured via the Web UI (not this env var).
# Valid types: "reneryo", "custom_rest"
# Leave empty for zero-config first run (DEC-005: UnconfiguredAdapter).
ADAPTER_TYPE=

# ============================================================================
# Web UI Authentication
# ============================================================================

# API key for Web UI and API access. All API requests (except /health) require
# this key in the X-API-Key header.
#
# Generate a secure key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# If not set, a random key is generated on startup and logged.
# AVAROS_WEB_API_KEY=

# ============================================================================
# HTTPS / TLS (Nginx Proxy)
# ============================================================================

# External ports mapped to the host
AVAROS_HTTPS_PORT=443
AVAROS_HTTP_PORT=80

# TLS mode: "self-signed" (testing) or "letsencrypt" (production)
AVAROS_TLS_MODE=self-signed

# ============================================================================
# General Settings
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
AVAROS_LOG_LEVEL=INFO

# Timezone
TZ=UTC

# ============================================================================
# HiveMind WebSocket Proxy (DEC-026)
# ============================================================================

# Port for the HiveMind WebSocket endpoint (browser voice clients connect here)
HIVEMIND_PORT=5678

# Master key for HiveMind administrative operations.
# Optional for local runs: if empty, entrypoint auto-generates a value.
# REQUIRED for shared/staging/production deployments — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
HIVEMIND_MASTER_KEY=

# Default client credentials for browser WebSocket connections.
# Optional for local runs: if empty, entrypoint auto-generates values.
# REQUIRED for shared/staging/production deployments — generate each with:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
HIVEMIND_CLIENT_NAME=avaros-web-client
HIVEMIND_CLIENT_KEY=
HIVEMIND_CLIENT_SECRET=
HIVEMIND_CLIENT_CRYPTO_KEY=

# Public WebSocket URL returned by the voice config endpoint to browser clients.
# Dev example (HTTPS via nginx):
HIVEMIND_WS_URL=wss://localhost/hivemind

# Optional allowlist for client message types (comma-separated).
# Keep the default unless you need tighter/looser policies.
HIVEMIND_CLIENT_ALLOWED_TYPES=recognizer_loop:utterance,recognizer_loop:record_begin,recognizer_loop:record_end,recognizer_loop:audio_output_start,recognizer_loop:audio_output_end,recognizer_loop:b64_transcribe,speak:b64_audio,ovos.common_play.SEI.get.response

# Compatibility aliases (legacy names used by older scripts)
# HIVEMIND_ACCESS_KEY=${HIVEMIND_CLIENT_KEY}
# HIVEMIND_PASSWORD=${HIVEMIND_CLIENT_SECRET}

# ============================================================================
# Mock RENERYO Server (Testing / Demo Only)
# ============================================================================

# Port for the mock RENERYO HTTP server
MOCK_RENERYO_PORT=8090

# Internal deploy host IP (used in docker-compose.avaros.yml extra_hosts).
# Only needed when connecting to a real RENERYO instance.
RENERYO_DEPLOYS_IP=

# ============================================================================
# Development Settings (Not for Production)
# ============================================================================

# Enable debug mode (more verbose logging)
# AVAROS_DEBUG=false

# Skip authentication (development only — never in production!)
# AVAROS_SKIP_AUTH=false
